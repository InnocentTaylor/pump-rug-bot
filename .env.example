# --- Telegram ---
# Get TELEGRAM_BOT_TOKEN from @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get TELEGRAM_CHAT_ID by messaging @userinfobot (for a DM) or @myidbot
# For a channel/group, add the bot as admin and use the channel's numeric ID (starts with -100)
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Solana RPC ---
# Public RPC works but is rate-limited and can lag. A dedicated RPC (Helius, QuickNode,
# Triton) free tier is strongly recommended for reliability at this speed.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Risk thresholds (tune to taste) ---
# Alert only when computed score is at or below this (0 = safest, 100 = worst)
ALERT_MAX_SCORE=40

# Flag if the creator's initial buy is more than this % of total supply
MAX_DEV_HOLD_PERCENT=15

# Flag if the top 10 holder wallets control more than this % of supply
MAX_TOP10_HOLD_PERCENT=40

# Flag if starting market cap (in SOL) is below this — very thin liquidity
MIN_MARKET_CAP_SOL=3
